# Anthropic (LLM)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# DOKU Sandbox
DOKU_CLIENT_ID=xxxxxxxxxxxxxxxx
DOKU_SECRET_KEY=xxxxxxxxxxxxxxxx
DOKU_BASE_URL=https://api-sandbox.doku.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+6289678283546
TWILIO_FALLBACK_ONLY=true

# OpenClaw (gateway WhatsApp utama — lihat docs/openclaw-integration.md)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_SEND_PATH=/tools/invoke
OPENCLAW_WEBHOOK_SECRET=laksa-openclaw-secret
OPENCLAW_PEER_PHONE=+6289678283546
OPENCLAW_WHATSAPP_ACCOUNT=default

# MySQL
# Docker (compose di repo): pakai user laksa — samakan dengan MYSQL_APP_PASSWORD (default laksa_app_dev)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=laksa
DB_PASSWORD=laksa_app_dev
DB_NAME=laksa_db

# Laporan harian otomatis (systemd timer laksa-laporan-harian)
LAPORAN_HARIAN_BUSINESS_ID=1
LAPORAN_WA_MAX_REKOMENDASI_CHARS=1200
LAKSA_INTERNAL_URL=http://127.0.0.1:8000
LAPORAN_HARIAN_TIMEOUT_DETIK=300

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
