[Unit]
Description=Laksa — laporan harian otomatis (run-agent scheduled)
After=network-online.target laksa.service
Wants=laksa.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/laksa
ExecStart=/var/www/laksa/scripts/jalankan_laporan_harian.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
